{
  "manifest_version": 3,
  "name": "Автономера — таблиця номерів",
  "version": "7.0",
  "description": "Пасивно фіксує запити e-driver і будує таблицю: номер, ціна, ТСЦ, регіон, тип ТЗ. Експорт CSV/JSON.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "downloads"
  ],
  "host_permissions": [
    "*://*.gov.ua/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.gov.ua/*"
      ],
      "js": [
        "inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.gov.ua/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Автономера — перехоплювач"
  }
}