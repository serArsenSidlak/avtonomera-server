{
  "manifest_version": 3,
  "name": "Автономера — збирач opendata",
  "version": "9.0",
  "description": "Поки ти вручну ходиш по opendata.hsc.gov.ua — тихо перехоплює відповіді й накопичує номери по регіонах. Далі: експорт у CSV, дедуп і відправка оновлень у свою базу.",
  "permissions": ["storage", "unlimitedStorage", "tabs"],
  "host_permissions": [
    "*://opendata.hsc.gov.ua/*",
    "https://34.123.136.171.nip.io/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["*://opendata.hsc.gov.ua/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["*://opendata.hsc.gov.ua/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Автономера — збирач opendata"
  }
}
