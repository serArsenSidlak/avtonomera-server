{
  "manifest_version": 3,
  "name": "Автономера — перехоплювач трафіку ГСЦ",
  "version": "1.1",
  "description": "Перехоплює запити/відповіді сайтів *.gov.ua (fetch/XHR) для проєкту Автономера.",
  "permissions": ["storage", "unlimitedStorage", "downloads"],
  "host_permissions": ["*://*.gov.ua/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["*://*.gov.ua/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["*://*.gov.ua/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": true
    }
  ],
  "action": { "default_popup": "popup.html", "default_title": "Автономера — перехоплювач" }
}
